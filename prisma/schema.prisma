  currentPhone String?
  occupation   String?
  address      String?
  photo        String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AlumniEvent {
  id                       String           @id @default(cuid())
  title                    String
  eventFor                 String           @default("all") // "all" | "class"
  sessionId                String?
  session                  AcademicSession? @relation(fields: [sessionId], references: [id])
  classId                  String?
  class                    Class?           @relation(fields: [classId], references: [id])
  section                  String?
  fromDate                 DateTime
  toDate                   DateTime
  note                     String?
  photo                    String?
  isActive                 Boolean          @default(true)
  eventNotificationMessage String?
  showOnWebsite            Boolean          @default(false)
  createdAt                DateTime         @default(now())
}

// ─── Admissions ───────────────────────────────────────────────────────────────

enum ApplicationStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model AdmissionApplication {
  id              String            @id @default(cuid())
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          String
  classAppliedFor String
  parentName      String
  parentPhone     String
  parentEmail     String?
  address         String?
  notes           String?
  status          ApplicationStatus @default(PENDING)
  reviewNote      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// ─── Finance (Income & Expense) ───────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

model IncomeHead {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  transactions Transaction[]
}

model ExpenseHead {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  transactions Transaction[]
}

model Transaction {
  id            String          @id @default(cuid())
  type          TransactionType
  name          String?
  invoiceNo     String?
  amount        Decimal         @db.Decimal(12, 2)
  date          DateTime        @db.Date
  note          String?
  attachment    String?
  incomeHeadId  String?
  incomeHead    IncomeHead?     @relation(fields: [incomeHeadId], references: [id])
  expenseHeadId String?
  expenseHead   ExpenseHead?    @relation(fields: [expenseHeadId], references: [id])
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
}

// ─── School Profile & System Settings ────────────────────────────────────────

model SchoolProfile {
  id               String  @id @default(cuid())
  name             String
  code             String?
  address          String?
  phone            String?
  email            String?
  website          String?
  logo             String?
  motto            String?
  currency         String  @default("GHS")
  dateFormat       String  @default("DD/MM/YYYY")
  country          String?
  state            String?
  city             String?
  feeDueDays       Int     @default(30)
  // Admission number auto-generation
  admPrefix        String?
  admStartFrom     Int     @default(1)
  admNoDigit       Int     @default(4)
  admAutoInsert    Boolean @default(true)
  // Staff ID auto-generation
  staffidPrefix    String?
  staffidStartFrom Int     @default(1)
  staffidNoDigit   Int     @default(4)
  staffidAutoInsert Boolean @default(true)
  // Other system toggles
  lowAttendanceLimit Int   @default(75)
  classTeacher     Boolean @default(true)
  studentTimeline  Boolean @default(true)
}

// ─── Custom Fields ────────────────────────────────────────────────────────────

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  TEXTAREA
}

model CustomField {
  id         String          @id @default(cuid())
  tableName  String // "students" or "staff"
  fieldLabel String
  fieldType  CustomFieldType @default(TEXT)
  options    String? // comma-separated for SELECT type
  isRequired Boolean         @default(false)
  isActive   Boolean         @default(true)
  order      Int             @default(0)
  createdAt  DateTime        @default(now())

  values CustomFieldValue[]
}

model CustomFieldValue {
  id            String      @id @default(cuid())
  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  belongTableId String // student or staff ID
  fieldValue    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([customFieldId, belongTableId])
}

// ─── Disable Reasons (for student/staff disable workflow) ─────────────────────

model DisableReason {
  id        String   @id @default(cuid())
  reason    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Payment Gateways ─────────────────────────────────────────────────────────

model PaymentGateway {
  id                 String   @id @default(cuid())
  paymentType        String   @unique // "stripe" | "paypal" | "razorpay" | "paytm" etc.
  apiUsername        String?
  apiSecretKey       String?
  apiPublishableKey  String?
  apiPassword        String?
  apiSignature       String?
  apiEmail           String?
  accountNo          String?
  isSandbox          Boolean  @default(true)  // true=testing, false=live
  isActive           Boolean  @default(false)
  chargeType         String?  // "percent" | "fixed"
  chargeValue        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

// ─── RBAC (Roles & Permissions) ───────────────────────────────────────────────

model PermissionGroup {
  id        Int                  @id @default(autoincrement())
  name      String               @unique
  shortCode String               @unique
  isActive  Boolean              @default(true)
  isSystem  Boolean              @default(false)
  createdAt DateTime             @default(now())

  categories PermissionCategory[]
}

model PermissionCategory {
  id            Int             @id @default(autoincrement())
  permGroupId   Int
  permGroup     PermissionGroup @relation(fields: [permGroupId], references: [id])
  name          String
  shortCode     String          @unique
  enableView    Boolean         @default(true)
  enableAdd     Boolean         @default(true)
  enableEdit    Boolean         @default(true)
  enableDelete  Boolean         @default(true)
  createdAt     DateTime        @default(now())

  rolePermissions RolePermission[]
}

model AppRole {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String?
  isActive     Boolean  @default(true)
  isSystem     Boolean  @default(false)
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())

  permissions RolePermission[]
  staffRoles  StaffAppRole[]
}

model RolePermission {
  id        String             @id @default(cuid())
  roleId    String
  role      AppRole            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permCatId Int
  permCat   PermissionCategory @relation(fields: [permCatId], references: [id], onDelete: Cascade)
  canView   Boolean            @default(false)
  canAdd    Boolean            @default(false)
  canEdit   Boolean            @default(false)
  canDelete Boolean            @default(false)

  @@unique([roleId, permCatId])
}

// Links a Staff member to an AppRole (separate from UserRole enum used for auth)
model StaffAppRole {
  id      String  @id @default(cuid())
  staffId String  @unique
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  roleId  String
  role    AppRole @relation(fields: [roleId], references: [id])
}

// ─── Holidays ─────────────────────────────────────────────────────────────────

model HolidayType {
  id        String    @id @default(cuid())
  name      String    @unique
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  holidays  Holiday[]
}

// ─── Grades & Divisions ───────────────────────────────────────────────────────

model Grade {
  id          String   @id @default(cuid())
  examType    String?
  gradeName   String
  percentFrom Float
  percentTo   Float
  gradePoint  Float?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── Holidays ─────────────────────────────────────────────────────────────────

model Holiday {
  id            String           @id @default(cuid())
  holidayTypeId String
  holidayType   HolidayType      @relation(fields: [holidayTypeId], references: [id])
  sessionId     String?
  session       AcademicSession? @relation(fields: [sessionId], references: [id])
  fromDate      DateTime         @db.Date
  toDate        DateTime         @db.Date
  description   String?
  isActive      Boolean          @default(true)
  frontSite     Boolean          @default(false)
  createdAt     DateTime         @default(now())
}

// ─── Sources & References (for enquiries / admissions) ────────────────────────

model Source {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Reference {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── Email Configuration ──────────────────────────────────────────────────────

model EmailConfig {
  id           String  @id @default(cuid())
  smtpHost     String  @default("")
  smtpPort     Int     @default(587)
  smtpUsername String  @default("")
  smtpPassword String  @default("")
  smtpSecure   String  @default("tls") // "tls" | "ssl" | "none"
  fromEmail    String  @default("")
  fromName     String  @default("")
  isActive     Boolean @default(false)
}

// ─── Notification Settings ────────────────────────────────────────────────────

model NotificationSetting {
  id                Int     @id @default(autoincrement())
  type              String  @unique // "fee_payment", "attendance_student", "exam_result", etc.
  label             String
  emailEnabled      Boolean @default(false)
  smsEnabled        Boolean @default(false)
  pushEnabled       Boolean @default(false)
}

// ─── SMS Configuration ────────────────────────────────────────────────────────

model SmsConfig {
  id       String  @id @default(cuid())
  provider String  @unique // "twilio" | "africas_talking" | "msg91" | "nexmo"
  apiKey   String  @default("")
  senderId String  @default("")
  username String  @default("")
  password String  @default("")
  isActive Boolean @default(false)
}

// ─── Staff Attendance Schedule (by role) ─────────────────────────────────────

model StaffAttendanceSchedule {
  id                    String              @id @default(cuid())
  role                  String              // "TEACHER" | "ACCOUNTANT" | "LIBRARIAN" etc.
  staffAttendanceTypeId String
  staffAttendanceType   StaffAttendanceType @relation(fields: [staffAttendanceTypeId], references: [id])
  entryTimeFrom         String              // "08:00"
  entryTimeTo           String              // "09:00"
  totalHours            String?
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())

  @@unique([role, staffAttendanceTypeId])
}

// ─── Admit Card Templates ─────────────────────────────────────────────────────

model AdmitCardTemplate {
  id           String   @id @default(cuid())
  template     String?
  heading      String?  @db.Text
  title        String?  @db.Text
  leftLogo     String?
  rightLogo    String?
  examName     String?
  schoolName   String?
  examCenter   String?
  sign         String?
  backgroundImg String?
  isName       Boolean  @default(true)
  isFatherName Boolean  @default(true)
  isMotherName Boolean  @default(true)
  isDob        Boolean  @default(true)
  isAdmissionNo Boolean @default(true)
  isRollNo     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Student Subject-Level Attendance ────────────────────────────────────────

model StudentSubjectAttendance {
  id               String         @id @default(cuid())
  studentSessionId String
  studentSession   StudentSession @relation(fields: [studentSessionId], references: [id])
  timetableSlotId  String
  timetableSlot    TimetableSlot  @relation(fields: [timetableSlotId], references: [id])
  attendanceTypeId String
  attendanceType   AttendanceType @relation(fields: [attendanceTypeId], references: [id])
  date             DateTime       @db.Date
  remark           String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([studentSessionId, timetableSlotId, date])
}

// ─── Share Content (document sharing between staff/students/parents) ──────────

model ShareContent {
  id          String   @id @default(cuid())
  sendTo      String?
  title       String?  @db.Text
  shareDate   DateTime?
  validUpto   DateTime?
  description String?  @db.Text
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Certificate Templates ────────────────────────────────────────────────────

model Certificate {
  id                  String   @id @default(cuid())
  certificateName     String
  certificateText     String   @db.Text
  leftHeader          String   @default("")
  centerHeader        String   @default("")
  rightHeader         String   @default("")
  leftFooter          String   @default("")
  rightFooter         String   @default("")
  centerFooter        String   @default("")
  backgroundImage     String?
  // createdFor: 1 = staff, 2 = students
  createdFor          Int      @default(2)
  status              Int      @default(1)
  headerHeight        Int      @default(0)
  contentHeight       Int      @default(0)
  footerHeight        Int      @default(0)
  contentWidth        Int      @default(0)
  enableStudentImage  Boolean  @default(false)
  enableImageHeight   Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── Marksheet Templates ─────────────────────────────────────────────────────

model TemplateMarksheet {
  id           String   @id @default(cuid())
  headerImage  String?
  template     String?
  heading      String?  @db.Text
  title        String?  @db.Text
  leftLogo     String?
  rightLogo    String?
  examName     String?
  schoolName   String?
  examCenter   String?
  leftSign     String?
  middleSign   String?
  rightSign    String?
  examSession  Int      @default(1)
  isName       Boolean  @default(true)
  isFatherName Boolean  @default(true)
  isMotherName Boolean  @default(true)
  isDob        Boolean  @default(true)
  isAdmissionNo Boolean @default(true)
  isRollNo     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Staff ID Card Templates ──────────────────────────────────────────────────

model StaffIdCard {
  id                     String   @id @default(cuid())
  title                  String
  schoolName             String
  schoolAddress          String
  background             String?
  logo                   String?
  signImage              String?
  headerColor            String?
  enableVerticalCard     Boolean  @default(false)
  enableStaffRole        Boolean  @default(true)
  enableStaffId          Boolean  @default(true)
  enableStaffDepartment  Boolean  @default(true)
  enableDesignation      Boolean  @default(true)
  enableName             Boolean  @default(true)
  enableFathersName      Boolean  @default(false)
  enableMothersName      Boolean  @default(false)
  enableDateOfJoining    Boolean  @default(true)
  enablePermanentAddress Boolean  @default(false)
  enableStaffDob         Boolean  @default(false)
  enableStaffPhone       Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ─── Student Timeline ─────────────────────────────────────────────────────────

model StudentTimeline {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id])
  title            String
  timelineDate     DateTime
  description      String   @db.Text
  document         String?
  status           String   @default("yes")
  createdStudentId String?
  date             DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Staff Timeline ───────────────────────────────────────────────────────────

model StaffTimeline {
  id           String   @id @default(cuid())
  staffId      String
  staff        Staff    @relation(fields: [staffId], references: [id])
  title        String
  timelineDate DateTime
  description  String
  document     String?
  status       String   @default("yes")
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── SaaS Registry (lives in public schema — shared across all tenants) ───────

model SchoolTenant {
  id           String    @id @default(cuid())
  name         String
  subdomain    String    @unique  // e.g. "sunshine" → sunshine.novalss.com
  customDomain String?   @unique  // e.g. "portal.sunshineacademy.edu.gh"
  schemaName   String    @unique  // postgres schema: "public" | "school_abc123"
  plan         String    @default("trial")   // "trial" | "basic" | "pro"
  status       String    @default("active")  // "active" | "trial" | "suspended"
  adminEmail   String
  adminName    String?
  phone        String?
  address      String?
  country      String    @default("Ghana")
  trialEndsAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
