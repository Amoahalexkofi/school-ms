  createdAt       DateTime        @default(now())

  acknowledgements HomeworkAcknowledgement[]
}

model HomeworkAcknowledgement {
  id           String   @id @default(cuid())
  homeworkId   String
  homework     Homework @relation(fields: [homeworkId], references: [id])
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([homeworkId, studentId])
}

// ─── Syllabus & Lesson Plans ──────────────────────────────────────────────────

model Syllabus {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  topic       String
  description String?
  status      String   @default("PENDING") // PENDING, COVERED
  sessionId   String?
  createdAt   DateTime @default(now())
}

enum LessonPlanStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model LessonPlan {
  id             String           @id @default(cuid())
  staffId        String
  staff          Staff            @relation(fields: [staffId], references: [id])
  subjectId      String
  subject        Subject          @relation(fields: [subjectId], references: [id])
  classSectionId String
  classSection   ClassSection     @relation(fields: [classSectionId], references: [id])
  sessionId      String
  session        AcademicSession  @relation(fields: [sessionId], references: [id])
  date           DateTime         @db.Date
  topic          String
  description    String?
  status         LessonPlanStatus @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

// ─── Transport ────────────────────────────────────────────────────────────────

model Vehicle {
  id              String   @id @default(cuid())
  vehicleNo       String   @unique
  vehicleModel    String?
  manufactureYear String?
  driverName      String?
  driverContact   String?
  driverLicence   String?
  vehiclePhoto    String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  routes Route[]
}

model Route {
  id        String   @id @default(cuid())
  title     String   @unique
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  routePickupPoints RoutePickupPoint[]
  studentRoutes     StudentRoute[]
}

model PickupPoint {
  id        String   @id @default(cuid())
  name      String   @unique
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  routePickupPoints RoutePickupPoint[]
  studentRoutes     StudentRoute[]
  studentSessions   StudentSession[]
}

model RoutePickupPoint {
  id                  String           @id @default(cuid())
  routeId             String
  route               Route            @relation(fields: [routeId], references: [id], onDelete: Cascade)
  pickupPointId       String
  pickupPoint         PickupPoint      @relation(fields: [pickupPointId], references: [id])
  timing              String?          // pickup_time
  fees                Decimal?         @db.Decimal(10, 2)
  destinationDistance Float?           // destination_distance
  order               Int              @default(0) // order_number
  sessionId           String?
  session             AcademicSession? @relation(fields: [sessionId], references: [id])

  studentSessions      StudentSession[]
  studentTransportFees StudentTransportFee[]

  @@unique([routeId, pickupPointId])
}

// transport_feemaster — monthly fee schedule for a session
model TransportFeemaster {
  id             String           @id @default(cuid())
  sessionId      String
  session        AcademicSession  @relation(fields: [sessionId], references: [id])
  month          String           // "January", "February", etc.
  dueDate        DateTime?        @db.Date
  fineAmount     Decimal          @default(0) @db.Decimal(10, 2)
  fineType       String           @default("none") // "none" | "percentage" | "fixed"
  finePercentage Decimal          @default(0) @db.Decimal(5, 2)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())

  studentTransportFees StudentTransportFee[]
}

// student_transport_fees — links a student session to a monthly transport fee
model StudentTransportFee {
  id                   String             @id @default(cuid())
  studentSessionId     String
  studentSession       StudentSession     @relation(fields: [studentSessionId], references: [id])
  routePickupPointId   String
  routePickupPoint     RoutePickupPoint   @relation(fields: [routePickupPointId], references: [id])
  transportFeemasterId String
  transportFeemaster   TransportFeemaster @relation(fields: [transportFeemasterId], references: [id])
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())

  deposits FeeDeposit[]
}

model StudentRoute {
  id            String       @id @default(cuid())
  studentId     String       @unique
  student       Student      @relation(fields: [studentId], references: [id])
  routeId       String
  route         Route        @relation(fields: [routeId], references: [id])
  pickupPointId String?
  pickupPoint   PickupPoint? @relation(fields: [pickupPointId], references: [id])
  assignedAt    DateTime     @default(now())
}

// id_card — printable ID card templates (configurable per school)
model IdCard {
  id         String   @id @default(cuid())
  heading    String?
  title      String?
  bgColor    String   @default("#1a56db")
  fontColor  String   @default("#ffffff")
  bodyColor  String   @default("#f9fafb")
  schoolName String?
  leftLogo   String?  // URL
  rightLogo  String?  // URL
  fieldList  Json?    // array of field names to display
  status     Int      @default(0) // 1 = active/default
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// ─── Hostel ───────────────────────────────────────────────────────────────────

model RoomType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  rooms HostelRoom[]
}

model Hostel {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String?
  address     String?
  intake      Int?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  rooms HostelRoom[]
}

model HostelRoom {
  id          String    @id @default(cuid())
  hostelId    String
  hostel      Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  roomNo      String
  roomTypeId  String?
  roomType    RoomType? @relation(fields: [roomTypeId], references: [id])
  capacity    Int       @default(1)
  costPerBed  Decimal?  @db.Decimal(10, 2)
  title       String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  allocations     HostelAllocation[]
  studentSessions StudentSession[]

