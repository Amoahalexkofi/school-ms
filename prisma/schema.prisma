generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  ACCOUNTANT
  LIBRARIAN
  STUDENT
  PARENT
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      UserRole
  isActive  Boolean  @default(true)
  childs    String? // comma-separated student IDs (parent accounts)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student          Student?
  staff            Staff?
  notifications    Notification[]
  chatParticipants ChatParticipant[]
  chatMessages     ChatMessage[]
}

// ─── Academic Session ─────────────────────────────────────────────────────────

model AcademicSession {
  id        String   @id @default(cuid())
  session   String   @unique // "2024-2025"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  studentSessions      StudentSession[]
  feeSessionGroups     FeeSessionGroup[]
  subjectGroups        SubjectGroup[]
  attendanceDays       AttendanceDay[]
  homeworkItems        Homework[]
  lessonPlans          LessonPlan[]
  examSchedules        ExamSchedule[]
  subjects             Subject[]
  holidays             Holiday[]
  alumniEvents         AlumniEvent[]
  routePickupPoints    RoutePickupPoint[]
  transportFeemasters  TransportFeemaster[]
}

// ─── Classes & Sections (independent masters, reused across sessions) ─────────

model Class {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  classSections ClassSection[]
  feeMasters    FeeMaster[]
  onlineExams   OnlineExam[]
  subjects      Subject[]
  questions     Question[]
  alumniEvents  AlumniEvent[]
}

model Section {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  classSections ClassSection[]
}

model ClassSection {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id])
  teacherId String?
  teacher   Staff?   @relation("ClassTeacher", fields: [teacherId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  studentSessions      StudentSession[]
  timetableSlots       TimetableSlot[]
  attendanceDays       AttendanceDay[]
  homeworkItems        Homework[]
  lessonPlans          LessonPlan[]
  attendanceSchedules  StudentAttendanceSchedule[]
  subjectGroupSections SubjectGroupSection[]
  classSectionTimes    ClassSectionTime[]

  @@unique([classId, sectionId])
}

model ClassSectionTime {
  id             String       @id @default(cuid())
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id])
  time           String       // "HH:MM" — attendance auto-mark trigger time
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ─── Subjects ─────────────────────────────────────────────────────────────────

enum SubjectType {
  THEORY
  PRACTICAL
}

model Subject {
  id        String          @id @default(cuid())
  name      String
  code      String
  type      SubjectType     @default(THEORY)
  classId   String
  class     Class           @relation(fields: [classId], references: [id])
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())

  teacherSubjects      TeacherSubject[]
  examSchedules        ExamSchedule[]
  markEntries          MarkEntry[]
  homeworkItems        Homework[]
  timetableSlots       TimetableSlot[]
  lessonPlans          LessonPlan[]
  syllabi              Syllabus[]
  questions            Question[]
  subjectGroupSubjects SubjectGroupSubject[]
}

model SubjectGroup {
  id          String          @id @default(cuid())
  name        String
  description String?
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  subjects SubjectGroupSubject[]
  sections SubjectGroupSection[]
}

model SubjectGroupSubject {
  id             String       @id @default(cuid())
  subjectGroupId String
  subjectGroup   SubjectGroup @relation(fields: [subjectGroupId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])

  @@unique([subjectGroupId, subjectId])
}

model SubjectGroupSection {
  id             String       @id @default(cuid())
  subjectGroupId String
  subjectGroup   SubjectGroup @relation(fields: [subjectGroupId], references: [id])
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id])
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@unique([subjectGroupId, classSectionId])
}

// ─── Departments & Designations ───────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  staff Staff[]
}

model Designation {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  staff Staff[]
}

// ─── Staff ────────────────────────────────────────────────────────────────────

enum ContractType {
  PERMANENT
  CONTRACT
  TEMPORARY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

model Staff {
  id                String         @id @default(cuid())
  userId            String         @unique
  user              User           @relation(fields: [userId], references: [id])
  employeeId        String         @unique
  departmentId      String?
  department        Department?    @relation(fields: [departmentId], references: [id])
  designationId     String?
  designation       Designation?   @relation(fields: [designationId], references: [id])
  firstName         String
  lastName          String
  fatherName        String?
  motherName        String?
  dob               DateTime?
  gender            String?
  maritalStatus     MaritalStatus?
  religion          String?
  qualification     String?
  workExperience    String?
  dateOfJoining     DateTime?
  dateOfLeaving     DateTime?
  contractType      ContractType?
  contactNo         String?
  emergencyContact  String?
  localAddress      String?
  permanentAddress  String?
  city              String?
  state             String?
  country           String?
  image             String?
  basicSalary       Decimal?       @db.Decimal(12, 2)
  bankAccountNo     String?
  bankName          String?
  ifscCode          String?
  bankBranch        String?
  accountTitle      String?
  epfNo             String?
  verificationCode  String?
  payscale          String?
  shift             String?
  location          String?
  facebook          String?
  twitter           String?
  linkedin          String?
  instagram         String?
  resume            String?
  joiningLetter     String?
  resignationLetter String?
  otherDocumentName String?
  otherDocumentFile String?
  note              String?
  isActive          Boolean        @default(true)
  disabledAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  classSectionsTeaching ClassSection[]      @relation("ClassTeacher")
  teacherSubjects       TeacherSubject[]
  attendanceRecords     StaffAttendance[]
  homeworkAssigned      Homework[]
  timetableSlots        TimetableSlot[]
  payslips              StaffPayslip[]
  leaveRequests         StaffLeaveRequest[]
  leaveBalances         StaffLeaveBalance[]
  bookIssues            BookIssue[]
  lessonPlans           LessonPlan[]
  notices               Notice[]
  messageLogs           MessageLog[]
  payrollEntries        PayrollEntry[]
  questions             Question[]
  appRole               StaffAppRole?
  timelines             StaffTimeline[]
}

model TeacherSubject {
  id        String  @id @default(cuid())
  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id])
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([staffId, subjectId])
}

// ─── School House ─────────────────────────────────────────────────────────────

model SchoolHouse {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  students Student[]
}

// ─── Students ─────────────────────────────────────────────────────────────────

model Student {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id])
  admissionNo        String       @unique
  rollNo             String?
  admissionDate      DateTime?
  firstName          String
  middleName         String?
  lastName           String?
  dateOfBirth        DateTime?
  gender             String?
  bloodGroup         String?
  religion           String?
  caste              String?
  category           String?
  nationality        String?
  rte                Boolean      @default(false)
  image              String?
  mobileNo           String?
  currentAddress     String?
  permanentAddress   String?
  city               String?
  state              String?
  country            String?
  pincode            String?
  // Guardian
  guardianIs         String?
  fatherName         String?
  fatherPhone        String?
  fatherOccupation   String?
  fatherPic          String?
  motherName         String?
  motherPhone        String?
  motherOccupation   String?
  motherPic          String?
  guardianName       String?
  guardianRelation   String?
  guardianPhone      String?
  guardianEmail      String?
  guardianOccupation String?
  guardianAddress    String?
  guardianPic        String?
  // Guardian extended
  fatherEmail        String?
  motherEmail        String?
  // Academic
  previousSchool     String?
  previousClass      String?
  previousPercent    String?
  previousTcNo       String?
  samagraId          String?
  schoolHouseId      String?
  schoolHouse        SchoolHouse? @relation(fields: [schoolHouseId], references: [id])
  // Physical
  height             String?
  weight             String?
  measurementDate    DateTime?
  // Bank
  bankAccountNo      String?
  bankName           String?
  bankBranch         String?
  ifscCode           String?
  aadharNo           String?
  // App keys
  appKey             String?
  parentAppKey       String?
  // Contact (mirrors students.email — separate from login User.email)
  email              String?
  // Parent user account link (mirrors students.parent_id)
  parentId           String?
  // Student designation/title (mirrors students.designation)
  designation        String?
  // Status
  note               String?
  about              String?
  isActive           Boolean      @default(true)
  disableReason      String?
  disableNote        String?
  disabledAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  sessions                 StudentSession[]
  markEntries              MarkEntry[]
  attendances              StudentAttendance[]
  homeworkAcknowledgements HomeworkAcknowledgement[]
  bookIssues               BookIssue[]
  transportRoute           StudentRoute?
  hostelAllocation         HostelAllocation?
  examAttempts             ExamAttempt[]
  leaveRequests            StudentLeaveRequest[]
  feesMasters              StudentFeesMaster[]
  appliedDiscounts         StudentAppliedDiscount[]
  alumni                   Alumni?
  timelines                StudentTimeline[]
}

model StudentSession {
  id             String          @id @default(cuid())
  studentId      String
  student        Student         @relation(fields: [studentId], references: [id])
  sessionId      String
  session        AcademicSession @relation(fields: [sessionId], references: [id])
  classSectionId String
  classSection   ClassSection    @relation(fields: [classSectionId], references: [id])
  rollNo             String?
  hostelRoomId       String?
  hostelRoom         HostelRoom?       @relation(fields: [hostelRoomId], references: [id])
  routeId            String?
  pickupPointId      String?
  routePickupPointId String?          // route_pickup_point_id — the specific stop assigned (Smart School)
  routePickupPoint   RoutePickupPoint? @relation(fields: [routePickupPointId], references: [id])
  pickupPointRef     PickupPoint?      @relation(fields: [pickupPointId], references: [id])
  transportFees      Decimal?          @db.Decimal(10, 2)
  feesDiscount       Decimal?          @db.Decimal(10, 2)
  isLeave            Boolean           @default(false)
  isActive           Boolean           @default(true)
  isAlumni           Boolean           @default(false)
  defaultLogin       Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  attendances             StudentAttendance[]
  feesMasters             StudentFeesMaster[]
  studentTransportFees    StudentTransportFee[]
  subjectAttendances      StudentSubjectAttendance[]

  @@unique([studentId, sessionId, classSectionId])
}

// ─── Fees Module (mirrors Smart School exactly) ───────────────────────────────

model FeeCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  feeTypes FeeType[]
}

model FeeType {
  id               String       @id @default(cuid())
  name             String
  code             String       @unique
  feeCategoryId    String?
  feeCategory      FeeCategory? @relation(fields: [feeCategoryId], references: [id])
  nature           String?      // "custom" for per-student custom fees
  studentSessionId String?      // set when nature = "custom"
  isSystem         Boolean      @default(false)
  description      String?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())

  feeGroupItems FeeGroupItem[]
  feeMasters    FeeMaster[]
}

enum FeeGroupNature {
  REGULAR
  CUSTOM
  SYSTEM
}

model FeeGroup {
  id          String         @id @default(cuid())
  name        String         @unique
  nature      FeeGroupNature @default(REGULAR)
  isSystem    Boolean        @default(false)
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())

  sessionGroups FeeSessionGroup[]
}

model FeeSessionGroup {
  id         String          @id @default(cuid())
  feeGroupId String
  feeGroup   FeeGroup        @relation(fields: [feeGroupId], references: [id])
  sessionId  String
  session    AcademicSession @relation(fields: [sessionId], references: [id])
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())

  items              FeeGroupItem[]
  studentFeesMasters StudentFeesMaster[]

  @@unique([feeGroupId, sessionId])
}

enum FineType {
  NONE
  PERCENTAGE
  AMOUNT
}

model FeeGroupItem {
  id                String          @id @default(cuid())
  feeSessionGroupId String
  feeSessionGroup   FeeSessionGroup @relation(fields: [feeSessionGroupId], references: [id], onDelete: Cascade)
  feeTypeId         String
  feeType           FeeType         @relation(fields: [feeTypeId], references: [id])
  amount            Decimal         @db.Decimal(10, 2)
  dueDate           DateTime?       @db.Date
  fineType          FineType        @default(NONE)
  finePercentage    Decimal         @default(0) @db.Decimal(5, 2)
  fineAmount        Decimal         @default(0) @db.Decimal(10, 2)
  finePerDay        Int             @default(0)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())

  deposits        FeeDeposit[]
  cumulativeFines CumulativeFine[]

  @@unique([feeSessionGroupId, feeTypeId])
}

model CumulativeFine {
  id             String       @id @default(cuid())
  feeGroupItemId String
  feeGroupItem   FeeGroupItem @relation(fields: [feeGroupItemId], references: [id], onDelete: Cascade)
  overdueDay     Int
  fineAmount     Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
}

// student_fees_master — one record per student per fee-session-group
model StudentFeesMaster {
  id                String          @id @default(cuid())
  studentId         String
  student           Student         @relation(fields: [studentId], references: [id])
  studentSessionId  String
  studentSession    StudentSession  @relation(fields: [studentSessionId], references: [id])
  feeSessionGroupId String
  feeSessionGroup   FeeSessionGroup @relation(fields: [feeSessionGroupId], references: [id])
  amount            Decimal         @default(0) @db.Decimal(10, 2)
  isSystem          Boolean         @default(false) // carry-forward balance flag
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())

  deposits FeeDeposit[]

  @@unique([studentSessionId, feeSessionGroupId])
}

// student_fees_deposite — actual payment records with JSON amount_detail
model FeeDeposit {
  id                    String               @id @default(cuid())
  studentFeesMasterId   String?
  studentFeesMaster     StudentFeesMaster?   @relation(fields: [studentFeesMasterId], references: [id])
  studentTransportFeeId String?              // set when collecting transport fees
  studentTransportFee   StudentTransportFee? @relation(fields: [studentTransportFeeId], references: [id])
  feeGroupItemId        String?
  feeGroupItem          FeeGroupItem?        @relation(fields: [feeGroupItemId], references: [id])
  // JSON: { "1": { amount, discount, fine, date, payment_mode, description, received_by, inv_no } }
  amountDetail          Json
  isActive              Boolean              @default(true)
  createdAt             DateTime             @default(now())
}

// fee_discounts — discount definitions
model FeeDiscount {
  id            String    @id @default(cuid())
  name          String
  code          String    @unique
  type          String // "percentage" or "amount"
  percentage    Decimal   @default(0) @db.Decimal(5, 2)
  amount        Decimal   @default(0) @db.Decimal(10, 2)
  discountLimit Int?
  expireDate    DateTime?
  description   String?
  isActive      Boolean   @default(true)
  sessionId     String?
  createdAt     DateTime  @default(now())

  studentDiscounts StudentFeeDiscount[]
}

// student_fees_discounts — discount assigned to a student
model StudentFeeDiscount {
  id               String      @id @default(cuid())
  studentSessionId String
  feeDiscountId    String
  feeDiscount      FeeDiscount @relation(fields: [feeDiscountId], references: [id])
  status           String      @default("assigned") // assigned, used, expired
  description      String?
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())

  appliedDiscounts StudentAppliedDiscount[]
}

// student_applied_discounts — audit trail
model StudentAppliedDiscount {
  id                   String              @id @default(cuid())
  studentId            String
  student              Student             @relation(fields: [studentId], references: [id])
  feeDepositId         String?
  studentFeeDiscountId String?
  studentFeeDiscount   StudentFeeDiscount? @relation(fields: [studentFeeDiscountId], references: [id])
  invoiceId            Int?
  subInvoiceId         Int?
  date                 DateTime            @default(now())
}

// feemasters — class-level fee template
model FeeMaster {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  feeTypeId   String
  feeType     FeeType  @relation(fields: [feeTypeId], references: [id])
  amount      Decimal  @db.Decimal(10, 2)
  sessionId   String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FeeReminder {
  id           String   @id @default(cuid())
  reminderType String // "before" or "after" due date
  day          Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model AttendanceType {
  id        String   @id @default(cuid())
  type      String   @unique // "Present", "Absent", "Late", "Holiday", "Half Day"
  keyValue  String   @unique // "P", "A", "L", "H", "F"
  longName  String?
  nameStyle String? // CSS class e.g. "label label-success"
  isActive  Boolean  @default(true)
  forQR     Boolean  @default(true)
  createdAt DateTime @default(now())

  studentAttendances        StudentAttendance[]
  schedules                 StudentAttendanceSchedule[]
  studentSubjectAttendances StudentSubjectAttendance[]
}

model StudentAttendanceSchedule {
  id               String         @id @default(cuid())
  classSectionId   String
  classSection     ClassSection   @relation(fields: [classSectionId], references: [id])
  attendanceTypeId String
  attendanceType   AttendanceType @relation(fields: [attendanceTypeId], references: [id])
  entryTimeFrom    String // "09:00"
  entryTimeTo      String // "09:30"
  totalHours       String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
}

model AttendanceDay {
  id             String          @id @default(cuid())
  date           DateTime        @db.Date
  classSectionId String
  classSection   ClassSection    @relation(fields: [classSectionId], references: [id])
  sessionId      String
  session        AcademicSession @relation(fields: [sessionId], references: [id])
  markedBy       String?
  createdAt      DateTime        @default(now())

  studentAttendances StudentAttendance[]

  @@unique([date, classSectionId])
}

model StudentAttendance {
  id               String         @id @default(cuid())
  studentId        String
  student          Student        @relation(fields: [studentId], references: [id])
  studentSessionId String
  studentSession   StudentSession @relation(fields: [studentSessionId], references: [id])
  attendanceDayId  String
  attendanceDay    AttendanceDay  @relation(fields: [attendanceDayId], references: [id])
  attendanceTypeId String
  attendanceType   AttendanceType @relation(fields: [attendanceTypeId], references: [id])
  inTime           String?
  outTime          String?
  remark           String?
  createdAt        DateTime       @default(now())

  @@unique([studentSessionId, attendanceDayId])
}

model StaffAttendanceType {
  id        String   @id @default(cuid())
  type      String   @unique
  keyValue  String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  staffAttendances          StaffAttendance[]
  staffAttendanceSchedules  StaffAttendanceSchedule[]
}

model StaffAttendance {
  id                    String              @id @default(cuid())
  staffId               String
  staff                 Staff               @relation(fields: [staffId], references: [id])
  date                  DateTime            @db.Date
  staffAttendanceTypeId String
  staffAttendanceType   StaffAttendanceType @relation(fields: [staffAttendanceTypeId], references: [id])
  inTime                String?
  outTime               String?
  remark                String?
  createdAt             DateTime            @default(now())

  @@unique([staffId, date])
}

// ─── Leave Management ─────────────────────────────────────────────────────────

model LeaveType {
  id          String   @id @default(cuid())
  name        String   @unique
  daysAllowed Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  staffLeaveRequests StaffLeaveRequest[]
  staffLeaveBalances StaffLeaveBalance[]
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model StaffLeaveRequest {
  id          String      @id @default(cuid())
  staffId     String
  staff       Staff       @relation(fields: [staffId], references: [id])
  leaveTypeId String
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id])
  fromDate    DateTime
  toDate      DateTime
  leaveDays   Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  remark      String?
  docs        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model StaffLeaveBalance {
  id          String    @id @default(cuid())
  staffId     String
  staff       Staff     @relation(fields: [staffId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  totalDays   Int       @default(0)
  usedDays    Int       @default(0)
  sessionId   String?
  createdAt   DateTime  @default(now())

  @@unique([staffId, leaveTypeId])
}

model StudentLeaveRequest {
  id         String      @id @default(cuid())
  studentId  String
  student    Student     @relation(fields: [studentId], references: [id])
  fromDate   DateTime
  toDate     DateTime
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  docs       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

// ─── Exams & Marks ────────────────────────────────────────────────────────────

model ExamGroup {
  id                String   @id @default(cuid())
  name              String
  examType          String?
  description       String?
  passingPercentage Float?   @default(33)
  isActive          Boolean  @default(true)
  isPublished       Boolean  @default(false)
  createdAt         DateTime @default(now())

  schedules ExamSchedule[]
}

model ExamSchedule {
  id             String          @id @default(cuid())
  examGroupId    String
  examGroup      ExamGroup       @relation(fields: [examGroupId], references: [id])
  sessionId      String
  session        AcademicSession @relation(fields: [sessionId], references: [id])
  subjectId      String
  subject        Subject         @relation(fields: [subjectId], references: [id])
  classSectionId String?
  dateOfExam     DateTime?       @db.Date
  startTime      String?
  endTime        String?
  roomNo         String?
  fullMarks      Int
  passingMarks   Int
  note           String?
  isActive       Boolean         @default(true)
  isPublished    Boolean         @default(false)
  createdAt      DateTime        @default(now())

  markEntries MarkEntry[]
}

model GradingScale {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  ranges GradeRange[]
}

model GradeRange {
  id             String       @id @default(cuid())
  gradingScaleId String
  gradingScale   GradingScale @relation(fields: [gradingScaleId], references: [id], onDelete: Cascade)
  grade          String
  gradePoint     Decimal      @db.Decimal(3, 1)
  markFrom       Decimal      @db.Decimal(5, 2)
  markTo         Decimal      @db.Decimal(5, 2)
  description    String?
  isActive       Boolean      @default(true)
}

model MarkDivision {
  id             String   @id @default(cuid())
  name           String // "Distinction", "First Class", "Second Class", "Fail"
  percentageFrom Decimal  @db.Decimal(5, 2)
  percentageTo   Decimal  @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model MarkEntry {
  id             String       @id @default(cuid())
  examScheduleId String
  examSchedule   ExamSchedule @relation(fields: [examScheduleId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  marksObtained  Decimal?     @db.Decimal(5, 2)
  attendance     String       @default("P") // "P" present, "A" absent
  grade          String?
  isPassing      Boolean      @default(false)
  note           String?
  createdAt      DateTime     @default(now())
  subject        Subject?     @relation(fields: [subjectId], references: [id])
  subjectId      String?

  @@unique([examScheduleId, studentId])
}

// ─── Payroll ──────────────────────────────────────────────────────────────────

enum PayslipStatus {
  DRAFT
  APPROVED
  PAID
}

model StaffPayslip {
  id             String        @id @default(cuid())
  staffId        String
  staff          Staff         @relation(fields: [staffId], references: [id])
  month          String // "01"–"12"
  year           String // "2024"
  basicSalary    Decimal       @db.Decimal(12, 2)
  totalAllowance Decimal       @default(0) @db.Decimal(12, 2)
  totalDeduction Decimal       @default(0) @db.Decimal(12, 2)
  leaveDeduction Int           @default(0)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  netSalary      Decimal       @db.Decimal(12, 2)
  status         PayslipStatus @default(DRAFT)
  paymentMode    String?
  paymentDate    DateTime?
  remark         String?
  generatedBy    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  allowances PayslipAllowance[]

  @@unique([staffId, month, year])
}

model PayslipAllowance {
  id          String       @id @default(cuid())
  payslipId   String
  payslip     StaffPayslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  staffId     String
  type        String // "HRA", "DA", "Bonus", "Tax Deduction", etc.
  amount      Decimal      @db.Decimal(12, 2)
  calType     String       @default("fixed") // "fixed", "percentage"
  isDeduction Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

// legacy bulk payroll
model Payroll {
  id        String        @id @default(cuid())
  month     Int
  year      Int
  status    PayrollStatus @default(PENDING)
  createdAt DateTime      @default(now())

  entries PayrollEntry[]

  @@unique([month, year])
}

enum PayrollStatus {
  PENDING
  PAID
}

model PayrollEntry {
  id          String   @id @default(cuid())
  payrollId   String
  payroll     Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id])
  basicSalary Decimal  @db.Decimal(12, 2)
  allowances  Decimal  @default(0) @db.Decimal(12, 2)
  deductions  Decimal  @default(0) @db.Decimal(12, 2)
  netSalary   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@unique([payrollId, staffId])
}

// ─── Timetable ────────────────────────────────────────────────────────────────

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model TimetableSlot {
  id             String       @id @default(cuid())
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id])
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])
  staffId        String?
  staff          Staff?       @relation(fields: [staffId], references: [id])
  day            DayOfWeek
  timeFrom       String
  timeTo         String
  roomNo         String?
  sessionId      String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

