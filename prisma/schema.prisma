}

model HostelAllocation {
  id          String     @id @default(cuid())
  studentId   String     @unique
  student     Student    @relation(fields: [studentId], references: [id])
  roomId      String
  room        HostelRoom @relation(fields: [roomId], references: [id])
  allocatedAt DateTime   @default(now())
}

// ─── Library ──────────────────────────────────────────────────────────────────

model Book {
  id          String   @id @default(cuid())
  title       String
  bookNo      String?  @unique
  isbn        String?  @unique
  subject     String?
  rackNo      String?
  publisher   String?
  author      String
  quantity    Int      @default(1)
  available   Int      @default(1)
  perUnitCost Decimal? @db.Decimal(10, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  issues BookIssue[]
}

enum BookIssueStatus {
  ISSUED
  RETURNED
  OVERDUE
}

model BookIssue {
  id         String          @id @default(cuid())
  bookId     String
  book       Book            @relation(fields: [bookId], references: [id])
  studentId  String?
  student    Student?        @relation(fields: [studentId], references: [id])
  staffId    String?
  staff      Staff?          @relation(fields: [staffId], references: [id])
  issuedAt   DateTime        @default(now())
  dueDate    DateTime
  returnedAt DateTime?
  status     BookIssueStatus @default(ISSUED)
  fine       Decimal?        @db.Decimal(10, 2)
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model ItemCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items Item[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items          Item[]
  stockMovements StockMovement[]
}

model Store {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items          Item[]
  stockMovements StockMovement[]
}

model Item {
  id            String        @id @default(cuid())
  name          String
  categoryId    String?
  category      ItemCategory? @relation(fields: [categoryId], references: [id])
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  storeId       String?
  store         Store?        @relation(fields: [storeId], references: [id])
  quantity      Int           @default(0)
  lowStockAlert Int           @default(5)
  unit          String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  stockMovements StockMovement[]
  issues         ItemIssue[]
}

enum StockMovementType {
  IN
  OUT
}

model StockMovement {
  id            String            @id @default(cuid())
  itemId        String
  item          Item              @relation(fields: [itemId], references: [id])
  type          StockMovementType
  quantity      Int
  purchasePrice Decimal?          @db.Decimal(10, 2)
  supplierId    String?
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  storeId       String?
  store         Store?            @relation(fields: [storeId], references: [id])
  note          String?
  date          DateTime          @default(now())
  createdAt     DateTime          @default(now())
}

model ItemIssue {
  id          String    @id @default(cuid())
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  issueType   String?   // "student" or "staff"
  issuedToId  String?   // studentId or staffId
  issuedTo    String?   // name (denormalised for display)
  issuedById  String?   // staff who issued
  quantity    Int
  returnDate  DateTime?
  isReturned  Boolean   @default(false)
  note        String?
  issuedAt    DateTime  @default(now())
}

