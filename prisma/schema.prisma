// ─── Online Exams ─────────────────────────────────────────────────────────────

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  DESCRIPTIVE
}

enum QuestionLevel {
  EASY
  MEDIUM
  HARD
}

model Question {
  id            String        @id @default(cuid())
  staffId       String?
  staff         Staff?        @relation(fields: [staffId], references: [id])
  subjectId     String?
  subject       Subject?      @relation(fields: [subjectId], references: [id])
  classId       String?
  class         Class?        @relation(fields: [classId], references: [id])
  sectionId     String?
  questionType  QuestionType  @default(MCQ)
  level         QuestionLevel @default(MEDIUM)
  question      String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  optionE       String?
  correctAnswer String?
  wordLimit     Int?
  image         String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  examQuestions OnlineExamQuestion[]
  answers       ExamAnswer[]
}

model OnlineExam {
  id                String   @id @default(cuid())
  title             String
  classId           String?
  class             Class?   @relation(fields: [classId], references: [id])
  sectionId         String?
  subjectId         String?
  sessionId         String?
  instructions      String?
  duration          Int
  totalQuestions    Int      @default(0)
  totalMarks        Float?
  passingPercentage Decimal? @db.Decimal(5, 2)
  negativeMarking   Boolean  @default(false)
  negativeMarks     Float?
  maxAttempts       Int      @default(1)
  startTime         DateTime
  endTime           DateTime
  isPublished       Boolean  @default(false)
  createdAt         DateTime @default(now())

  questions OnlineExamQuestion[]
  attempts  ExamAttempt[]
}

model OnlineExamQuestion {
  id           String     @id @default(cuid())
  onlineExamId String
  onlineExam   OnlineExam @relation(fields: [onlineExamId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id])
  marks        Int        @default(1)
  negMarks     Float?     @default(0)
  order        Int        @default(0)

  @@unique([onlineExamId, questionId])
}

model ExamAttempt {
  id           String     @id @default(cuid())
  onlineExamId String
  onlineExam   OnlineExam @relation(fields: [onlineExamId], references: [id])
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  startedAt    DateTime   @default(now())
  submittedAt  DateTime?
  score        Int?
  total        Int?

  answers ExamAnswer[]

  @@unique([onlineExamId, studentId])
}

model ExamAnswer {
  id            String      @id @default(cuid())
  attemptId     String
  attempt       ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id])
  selectedIndex Int?
  textAnswer    String?
  isCorrect     Boolean     @default(false)

  @@unique([attemptId, questionId])
}

